          "jsCode": "// Convert the rendered PNG to the same data-URL JSON shape the hero branch produces.\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nreturn [{\n  json: {\n    'omImage ': JSON.stringify({ url: 'data:image/png;base64,' + buffer.toString('base64') }),\n    prompt: $('parse_llm_output').item.json.text,\n  },\n}];\n"
