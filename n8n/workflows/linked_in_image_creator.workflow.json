        "jsCode": "// Parse the <visual> block: mode decides whether we render Mermaid or call the image model.\nconst raw = $input.first().json.text || '';\nconst grab = (tag) => {\n  const m = raw.match(new RegExp('<' + tag + '>([\\\\s\\\\S]*?)</' + tag + '>'));\n  return m ? m[1].trim() : '';\n};\nconst mode = (grab('mode') || 'hero').toLowerCase();\nconst mermaid = grab('mermaid').replace(/^```(mermaid)?\\s*/, '').replace(/```\\s*$/, '').trim();\nconst imagePrompt = grab('image_prompt');\nreturn [{\n  json: {\n    mode,\n    concept: grab('concept'),\n    headline: grab('headline'),\n    text: mode === 'diagram' && mermaid ? mermaid : (imagePrompt || raw),\n  },\n}];\n"
      },
