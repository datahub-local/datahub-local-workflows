{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "pipeline",
      "type": "command",
      "command": "shellCommand.execute",
      "args": {
        "command": "find ${workspaceFolder}/pipelines -maxdepth 2 -path '*/config.y*ml' | sed 's|.*/\\([^/]*\\)/config.*|\\1|' | sort -u"
      }
    }
  ],
  "configurations": [
    {
      "name": "SQLMesh: plan",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/.venv/bin/sqlmesh",
      "args": [
        "-p",
        "pipelines/${input:pipeline}",
        "--gateway",
        "local",
        "--dotenv",
        "${workspaceFolder}/pipelines/${input:pipeline}/.env.local",
        "plan"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "SQLMesh: run",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/.venv/bin/python",
      "program": "${workspaceFolder}/.venv/bin/sqlmesh",
      "args": [
        "-p",
        "pipelines/${input:pipeline}",
        "--gateway",
        "local",
        "--dotenv",
        "${workspaceFolder}/pipelines/${input:pipeline}/.env.local",
        "run"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}